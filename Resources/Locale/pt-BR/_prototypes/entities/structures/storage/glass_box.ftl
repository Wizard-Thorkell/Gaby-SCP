    .desc = { ent-GlassBoxLaser.desc }
ent-GlassBoxLaserFilled = { ent-GlassBoxLaser }
    .suffix = Laser antigo preenchido
    .desc = { ent-GlassBoxLaser.desc }
ent-GlassBoxLaserFilledOpen = { ent-GlassBoxLaserFilled }
    .suffix = Laser antigo, preenchido, aberto
    .desc = { ent-GlassBoxLaserFilled.desc }
ent-GlassBoxFrame = moldura de caixa de vidro
    .desc = Uma vitrine sem vidro para uma exposição cara.
    .suffix = Quadro
ent-GlassBoxBroken = caixa de vidro quebrada
    .desc = Uma vitrine quebrada para uma exposição cara.
    .suffix = Quebrado
