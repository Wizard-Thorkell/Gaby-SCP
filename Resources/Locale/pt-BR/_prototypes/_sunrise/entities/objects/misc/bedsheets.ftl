ent-DoubleBedsheetBase = cobertor grande
    .desc = Cobertor de linho incrivelmente macio.
ent-DoubleBedsheetBlack = cobertor preto
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetBlue = cobertor azul
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetBrown = cobertor marrom
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetCaptain = cobertor do capitão
    .desc = Possui o símbolo NanoTrasen e foi tecido a partir de um novo tipo revolucionário de fio com garantia de 0,01% de permeabilidade à maioria dos produtos não químicos, um favorito entre a maioria dos capitães modernos.
ent-DoubleBedsheetCE = Cobertor do engenheiro-chefe
    .desc = Decorado com um logotipo de chave inglesa. É altamente reflexivo e resistente a manchas, então você não precisa se preocupar em estragá-lo com óleo.
ent-DoubleBedsheetCentcom = cobertor CentCom
    .desc = O produto é tecido a partir de modernos nanofios, que proporcionam calor e são uma decoração maravilhosa, necessária para todos os funcionários.
ent-DoubleBedsheetClown = cobertor de palhaço
    .desc = Cobertor arco-íris com máscara de palhaço tecida. Cheira levemente a banana.
ent-DoubleBedsheetCMO = cobertor médico chefe
    .desc = Este é um cobertor esterilizado com um emblema em forma de cruz. Ele tem alguns pelos de gato, provavelmente do Runtime.
ent-DoubleBedsheetCosmos = cobertor espacial
    .desc = Criado a partir dos sonhos de quem admira as estrelas.
ent-DoubleBedsheetCult = cobertor de culto
    .desc = Se você dormir com isso, poderá sonhar com Nar'Sie. Ele parece um tanto maltrapilho e brilha com uma presença sobrenatural.
ent-DoubleBedsheetGreen = cobertor verde
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetGrey = cobertor cinza
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetHOP = cobertor de chefe de pessoal
    .desc = Está decorado com o emblema da chave de criptografia. Para aqueles raros momentos em que você pode relaxar e abraçar Ian sem que alguém grite com você no rádio.
ent-DoubleBedsheetHOS = cobertor do chefe de segurança
    .desc = Decorado com emblema de escudo. Enquanto o crime está acordado, você dorme, mas ainda é a LEI!
ent-DoubleBedsheetIan = Cobertor de Ian
    .desc = { ent-DoubleBedsheetBase.desc } Propriedade do próprio Ian.
ent-DoubleBedsheetMedical = cobertor médico.
    .desc = Este é um cobertor esterilizado comumente usado na enfermaria médica. A esterilização é inválida se um virologista estiver presente a bordo da estação.
ent-DoubleBedsheetMime = cobertor de mímico
    .desc = Um cobertor listrado muito reconfortante. Todo o barulho simplesmente desaparece quando você está embaixo dele.
ent-DoubleBedsheetNT = cobertor NanoTrasen
    .desc = Possui o logotipo NanoTrasen e um senso de dever.
ent-DoubleBedsheetOrange = cobertor laranja
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetPurple = cobertor roxo
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetQM = cobertor de intendente
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetRainbow = cobertor arco-íris
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetRD = cobertor do diretor de pesquisa
    .desc = Possui um emblema em forma de copo e é feito de material resistente ao fogo, embora seja improvável que o proteja em caso de incêndio, que você encontra todos os dias.
ent-DoubleBedsheetRed = cobertor vermelho
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetSyndie = cobertor do Sindicato
    .desc = Ele tem o emblema do sindicato e uma aura do mal.
ent-DoubleBedsheetUSA = cobertor EUA
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetWhite = cobertor branco
    .desc = { ent-DoubleBedsheetBase.desc }
ent-DoubleBedsheetWiz = cobertor mágico
    .desc = Tecido especial encantado com magia para garantir que você tenha uma noite mágica. Até brilha!
ent-DoubleBedsheetYellow = cobertor amarelo
    .desc = { ent-DoubleBedsheetBase.desc }
