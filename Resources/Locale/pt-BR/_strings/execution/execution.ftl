execution-verb-name = Executar
execution-verb-message = Use sua arma para executar alguém.
suicide-verb-name = Suicídio
suicide-verb-message = Use suas armas para sobreviver.

# All the below localisation strings have access to the following variables
# attacker (the person committing the execution)
# victim (the person being executed)
# weapon (the weapon used for the execution)

execution-popup-gun-initial-internal = Você aponta o cano de { $weapon } para a cabeça de { $victim }.
execution-popup-gun-initial-external = { $attacker } aponta o cano de { $weapon } para a cabeça de { $victim }.
execution-popup-gun-complete-internal = Você atira em { $victim } na cabeça!
execution-popup-gun-complete-external = { $attacker } atira em { $victim } na cabeça!
execution-popup-gun-clumsy-internal = Você erra a cabeça de { $victim } e em vez disso dá um tiro no próprio pé!
execution-popup-gun-clumsy-external = { $attacker } erra { $victim } e dá um tiro no próprio pé!
execution-popup-gun-empty = { CAPITALIZE($weapon) } cliques.
execution-popup-ammo-empty = O cartucho está gasto.
suicide-popup-gun-initial-internal = Você coloca o barril de { $weapon } na boca.
suicide-popup-gun-initial-external = { $attacker } coloca o barril de { $weapon } na boca.
suicide-popup-gun-complete-internal = Você está dando um tiro na cabeça!
suicide-popup-gun-complete-external = { $attacker } dá um tiro na cabeça!
suicide-popup-melee-complete-internal = Você está cortando sua própria garganta!
suicide-popup-melee-complete-external = { $attacker } corta a própria garganta!
suicide-popup-melee-initial-internal = Você colocou { $weapon } na garganta.
suicide-popup-melee-initial-external = { $attacker } coloca { $weapon } em sua garganta.
execution-popup-melee-initial-internal = Você colocou { $weapon } na garganta de { $victim }.
execution-popup-melee-initial-external = { $attacker } coloca { $weapon } oposto à garganta de { $victim }.
execution-popup-melee-complete-internal = Você cortou a garganta de { $victim }!
execution-popup-melee-complete-external = { $attacker } corta a garganta de { $victim }!
execution-popup-self-initial-internal = Você colocou { $weapon } contra sua própria garganta.
execution-popup-self-initial-external = { $attacker } coloca { $weapon } contra sua garganta.
execution-popup-self-complete-internal = Você está cortando sua própria garganta!
execution-popup-self-complete-external = { $attacker } corta a própria garganta!
