### UI

# Verb name for climbing
comp-climbable-verb-climb = Escalar

### Interaction Messages

# Shown to you when your character climbs on $climbable
comp-climbable-user-climbs = Você está escalando { $climbable }!
# Shown to others when $user climbs on $climbable
comp-climbable-user-climbs-other = { CAPITALIZE($user) } sobe { $climbable }!
# Shown to you when your character force someone to climb on $climbable
comp-climbable-user-climbs-force = Você força { $moved-user } a escalar { $climbable }!
# Shown to others when someone force other $moved-user to climb on $climbable
comp-climbable-user-climbs-force-other = { CAPITALIZE($user) } faz com que { $moved-user } suba { $climbable }!
# Shown to you when your character is far away from climbable
comp-climbable-cant-reach = Você não pode chegar lá!
# Shown to you when your character can't interact with climbable for some reason
comp-climbable-cant-interact = Você não pode fazer isso!
# Shown to you when your character can't climb
comp-climbable-cant-climb = Você não pode escalar!
# Shown to you when your character tries to force someone else who can't climb onto a climbable
comp-climbable-target-cant-climb = { CAPITALIZE($moved-user) } não consigo escalar!
